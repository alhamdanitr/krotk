# Kurotek Platform Environment Variables (EXAMPLE)
# =======================================

# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/kurotek?schema=public"

# ── Backend Settings ──
NODE_ENV=development
PORT=3000
JWT_SECRET="your_jwt_secret"
JWT_EXPIRES_IN="7d"

# ── Frontend Settings ──
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:3000/ws"

# ── Security ──
CORS_ORIGIN="http://localhost:3001"
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
