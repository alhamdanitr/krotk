# متغيرات البيئة المطلوبة لتشغيل kayan_repo/backend (NestJS)
# لا تضع قيمًا حقيقية في هذا الملف؛ فقط أضفها في بيئة النشر الفعلية (Railway/Render/…).

# مفتاح توقيع JWT — استخدم قيمة عشوائية طويلة، مثلاً: openssl rand -hex 32
# ملاحظة: يجب أن يكون هذا مطابقًا لنفس القيمة إذا كان هناك سيرفر آخر يتحقق من نفس التوكنات.
JWT_SECRET=

# اتصال قاعدة بيانات PostgreSQL (Prisma)
DATABASE_URL=

# مفتاح توقيع HMAC للتحقق من صحة طلبات تفعيل السيريال من التطبيقات
HMAC_SECRET=

# الملح (Salt) المستخدم في توليد بصمة السيريال بدون اتصال بالإنترنت
SERIAL_OFFLINE_SALT=
