# متغيرات البيئة المطلوبة لتشغيل server/api_server.js
# على Render: Dashboard → Service → Environment → أضف كل متغير هنا بقيمة حقيقية.
# لا تضع أي قيم حقيقية داخل هذا الملف نفسه، ولا تضف هذا الملف بقيم حقيقية إلى Git.

# مفتاح توقيع JWT — استخدم قيمة عشوائية طويلة، مثلاً: openssl rand -hex 32
JWT_SECRET=

# مفتاح توقيع HMAC للتحقق من صحة طلبات تفعيل السيريال — أيضًا: openssl rand -hex 32
HMAC_SECRET=

# بيانات دخول لوحة الإدارة (تُستخدم من تطبيق serial-admin وصفحة admin_panel.html)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# اتصال قاعدة بيانات PostgreSQL (Render يوفرها تلقائيًا عادةً كـ DATABASE_URL)
DATABASE_URL=
