# Kurotek Platform Environment Variables (RAILWAY PRODUCTION)
# ==============================================================

# ── Database (Provided automatically by Railway PostgreSQL plugin) ──
# DATABASE_URL gets injected automatically, but you can set it if external.
# DATABASE_URL="postgresql://postgres:password@containers-us-west-XX.railway.app:5432/railway"

# ── Backend Settings ──
NODE_ENV=production
# PORT is automatically injected by Railway
# PORT=3000
JWT_SECRET="generate_a_very_secure_random_string_here_for_production"
JWT_EXPIRES_IN="7d"

# ── Frontend Settings (Set these in Railway Dashboard for Next.js service) ──
NEXT_PUBLIC_API_URL="https://kurotek-backend-production.up.railway.app"
NEXT_PUBLIC_WS_URL="wss://kurotek-backend-production.up.railway.app/ws"

# ── Security ──
CORS_ORIGIN="https://kurotek-admin-production.up.railway.app"
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
