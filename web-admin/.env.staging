# Kurotek Platform Environment Variables (STAGING)
# =======================================

# ── Database ──
DATABASE_URL="postgresql://kurotek_user:staging_password@db_staging:5432/kurotek_staging?schema=public"

# ── Backend Settings ──
NODE_ENV=staging
PORT=3000
JWT_SECRET="staging_jwt_secret_do_not_use_in_prod"
JWT_EXPIRES_IN="7d"

# ── Frontend Settings ──
NEXT_PUBLIC_API_URL="https://staging-api.yourdomain.com"
NEXT_PUBLIC_WS_URL="wss://staging-api.yourdomain.com/ws"

# ── Security ──
CORS_ORIGIN="https://staging-dashboard.yourdomain.com"
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=200
